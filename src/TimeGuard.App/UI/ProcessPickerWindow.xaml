<Window x:Class="TimeGuard.UI.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick a Running Process"
        Width="340" Height="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource DarkBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a running process to monitor:"
                   Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" x:Name="SearchBox"
                 Background="{StaticResource SurfaceBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="{StaticResource AccentBrush}"
                 Padding="8,5" Margin="0,0,0,8"
                 TextChanged="OnSearchChanged"
                 Tag="Filter..."/>

        <ListBox Grid.Row="2" x:Name="ProcessList"
                 Background="{StaticResource SurfaceBrush}"
                 Foreground="{StaticResource TextBrush}"
                 BorderBrush="Transparent"
                 Margin="0,0,0,12"
                 MouseDoubleClick="OnDoubleClick"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Select" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="OnSelect"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
