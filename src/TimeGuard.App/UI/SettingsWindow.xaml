<Window x:Class="TimeGuard.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeGuard Settings"
        Width="700" Height="520"
        MinWidth="600" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DarkBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="⚙️ TimeGuard Settings"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Tab control -->
        <TabControl Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="Transparent">

            <!-- Rules Tab -->
            <TabItem Header="App Rules" Foreground="{StaticResource TextBrush}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="RulesGrid"
                              Grid.Row="0"
                              AutoGenerateColumns="False"
                              Background="{StaticResource DarkBrush}"
                              Foreground="{StaticResource TextBrush}"
                              RowBackground="{StaticResource DarkBrush}"
                              AlternatingRowBackground="{StaticResource SurfaceBrush}"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn  Header="On"          Binding="{Binding Enabled}"              Width="40"/>
                            <DataGridTextColumn      Header="App Name"    Binding="{Binding DisplayName}"          Width="*"/>
                            <DataGridTextColumn      Header="Process"     Binding="{Binding ProcessName}"          Width="110"/>
                            <DataGridTextColumn      Header="Limit (min)" Binding="{Binding DailyLimitMinutes}"    Width="80"/>
                            <DataGridTextColumn      Header="From"        Binding="{Binding AllowedWindowStart}"   Width="60"/>
                            <DataGridTextColumn      Header="To"          Binding="{Binding AllowedWindowEnd}"     Width="60"/>
                            <DataGridTextColumn      Header="Break every" Binding="{Binding BreakEveryMinutes}"    Width="80"/>
                            <DataGridTextColumn      Header="Break dur."  Binding="{Binding BreakDurationMinutes}" Width="75"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="🔍 Pick Process" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnPickProcess"/>
                        <Button Content="➕ Add Rule"     Style="{StaticResource PrimaryButton}"   Margin="0,0,8,0" Click="OnAddRule"/>
                        <Button Content="✏️ Edit"         Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" Click="OnEditRule"/>
                        <Button Content="🗑️ Delete"       Style="{StaticResource SecondaryButton}" Click="OnDeleteRule"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Global Cap Tab -->
            <TabItem Header="Daily Cap" Foreground="{StaticResource TextBrush}">
                <StackPanel Margin="20">
                    <TextBlock Text="Overall daily screen time cap (across all monitored apps)"
                               Foreground="{StaticResource SubtextBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Max minutes per day:" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="OverallCapBox"
                                 Width="80"
                                 Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderBrush="{StaticResource AccentBrush}"
                                 Padding="6,4"/>
                        <TextBlock Text="(0 = no cap)" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Usage History Tab -->
            <TabItem Header="Today's Usage" Foreground="{StaticResource TextBrush}">
                <DataGrid x:Name="UsageGrid"
                          Margin="12"
                          AutoGenerateColumns="False"
                          Background="{StaticResource DarkBrush}"
                          Foreground="{StaticResource TextBrush}"
                          RowBackground="{StaticResource DarkBrush}"
                          AlternatingRowBackground="{StaticResource SurfaceBrush}"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Process"         Binding="{Binding ProcessName}"            Width="*"/>
                        <DataGridTextColumn Header="Used (min)"      Binding="{Binding UsageMinutesDisplay}"    Width="100"/>
                        <DataGridTextColumn Header="Blocked Today"   Binding="{Binding Blocked}"                Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- Security Tab -->
            <TabItem Header="Security" Foreground="{StaticResource TextBrush}">
                <StackPanel Margin="20">
                    <TextBlock Text="Change password" Foreground="{StaticResource TextBrush}" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock Text="New password:" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="NewPasswordBox" Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource AccentBrush}"
                                 Padding="8,6" Margin="0,0,0,8" Width="220" HorizontalAlignment="Left"/>
                    <TextBlock Text="Confirm:" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                    <PasswordBox x:Name="ConfirmPasswordBox" Background="{StaticResource SurfaceBrush}"
                                 Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource AccentBrush}"
                                 Padding="8,6" Margin="0,0,0,12" Width="220" HorizontalAlignment="Left"/>
                    <Button Content="Change Password" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Click="OnChangePassword"/>
                    <TextBlock x:Name="PasswordStatusText" Foreground="{StaticResource AccentBrush}"
                               FontSize="11" Margin="0,8,0,0" Visibility="Collapsed"/>

                    <Separator Background="{StaticResource SurfaceBrush}" Margin="0,20"/>

                    <CheckBox x:Name="StartupCheckBox"
                              Content="Launch TimeGuard when Windows starts"
                              Foreground="{StaticResource TextBrush}"
                              Margin="0,0,0,0"
                              Checked="OnStartupToggle" Unchecked="OnStartupToggle"/>
                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="📊 Dashboard" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" Click="OnViewDashboard"/>
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="OnSave"/>
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
