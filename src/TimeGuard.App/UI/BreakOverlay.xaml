<Window x:Class="TimeGuard.UI.BreakOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Break Time"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#DD1E1E2E"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        KeyDown="OnKeyDown">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="☕ Break Time!"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="36" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,16"/>
            <TextBlock x:Name="AppNameText"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="18"
                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Take a break and rest your eyes."
                       Foreground="{StaticResource SubtextBrush}"
                       FontSize="14"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>
            <TextBlock x:Name="CountdownText"
                       Foreground="White"
                       FontSize="72" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>
            <TextBlock Text="You can resume when the timer ends."
                       Foreground="{StaticResource SubtextBrush}"
                       FontSize="13"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
