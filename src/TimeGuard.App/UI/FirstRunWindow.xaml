<Window x:Class="TimeGuard.UI.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to TimeGuard"
        Width="420" Height="360"
        MinHeight="340"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DarkBrush}">
    <StackPanel Margin="32">
        <TextBlock Text="👋 Welcome to TimeGuard"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="18" FontWeight="Bold" Margin="0,0,0,6"/>
        <TextBlock Text="Set a parent password to protect settings. You'll use this to add or change app time limits."
                   Foreground="{StaticResource SubtextBrush}"
                   FontSize="12" TextWrapping="Wrap" Margin="0,0,0,24"/>

        <TextBlock Text="Choose a password:" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PasswordBox"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource AccentBrush}"
                     Padding="8,6" Margin="0,0,0,10"/>

        <TextBlock Text="Confirm password:" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
        <PasswordBox x:Name="ConfirmBox"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource AccentBrush}"
                     Padding="8,6" Margin="0,0,0,12"/>

        <TextBlock x:Name="ErrorText" Foreground="{StaticResource AccentBrush}"
                   FontSize="11" Margin="0,0,0,12" Visibility="Collapsed"/>

        <Button Content="Get Started →"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right"
                Click="OnStart"/>
    </StackPanel>
</Window>
