<Window x:Class="TimeGuard.UI.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TimeGuard — Parent Access"
        Width="340" Height="220"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DarkBrush}">
    <StackPanel Margin="28">
        <TextBlock Text="🔒 Parent Settings"
                   Foreground="{StaticResource TextBrush}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="Enter your password to continue."
                   Foreground="{StaticResource SubtextBrush}"
                   FontSize="12" Margin="0,0,0,20"/>

        <PasswordBox x:Name="PasswordBox"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextBrush}"
                     BorderBrush="{StaticResource AccentBrush}"
                     Padding="8,6" Margin="0,0,0,8"
                     KeyDown="OnKeyDown"/>

        <TextBlock x:Name="ErrorText"
                   Foreground="{StaticResource AccentBrush}"
                   FontSize="11" Margin="0,0,0,12" Visibility="Collapsed"/>

        <Button Content="Unlock"
                Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right"
                Click="OnUnlock"/>
    </StackPanel>
</Window>
