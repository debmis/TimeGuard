<Window x:Class="TimeGuard.UI.WarningPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Time Warning"
        Width="360" Height="160"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Border Background="{StaticResource DarkBrush}"
            CornerRadius="12"
            BorderBrush="{StaticResource AccentBrush}"
            BorderThickness="2"
            Padding="20">
        <StackPanel>
            <TextBlock Text="⏳ Almost out of time!"
                       Foreground="{StaticResource AccentBrush}"
                       FontSize="14" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBlock x:Name="MessageText"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="13" TextWrapping="Wrap" Margin="0,0,0,16"/>
            <Button Content="OK, got it"
                    Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right"
                    Click="OnOkClick"/>
        </StackPanel>
    </Border>
</Window>
